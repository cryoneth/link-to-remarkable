# reMarkable token file (shared with telegram-monitor is fine)
RMAPI_TOKEN_FILE=~/.config/link2rm/rmapi-token

# Destination folder on reMarkable (must exist, create it from the tablet)
REMARKABLE_FOLDER=/Articles/Inbox

# Optional: enable LLM cleanup globally (per-request --llm flag takes precedence)
LLM_CLEANUP=false

# Required only if LLM_CLEANUP=true or --llm flag is used
ANTHROPIC_API_KEY=

# Server bind settings
HOST=0.0.0.0
PORT=8765

# Log location
LINK2RM_LOG_FILE=~/.link2rm/log.jsonl
